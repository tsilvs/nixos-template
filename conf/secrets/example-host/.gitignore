# Plaintext secret exports — NEVER commit these.
# sops decrypts to these patterns when run with -d / --decrypt to a file.
*.dec
*.plain

# Raw key material
*.key
*.pem
*.p12
id_*
!id_*.pub

# secrets.yaml itself IS committed (sops-encrypted ciphertext).
# secrets.yaml.example IS committed (schema reference, no real values).
