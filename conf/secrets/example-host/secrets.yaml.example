# conf/secrets/example-host/secrets.yaml.example
# ─────────────────────────────────────────────────────────────────────────────
# Schema reference for the sops-encrypted secrets.yaml file.
# This file is NOT encrypted and NOT the real secrets file.
#
# To create the real encrypted file:
#   sops conf/secrets/example-host/secrets.yaml
#   # Fill in values below; sops saves AES-256-GCM ciphertext.
#
# The real secrets.yaml will look like:
#   admin-password: ENC[AES256_GCM,data:...,tag:...,type:str]
#   sops:
#     age: [...]
#     ...
# ─────────────────────────────────────────────────────────────────────────────

# User login password (hashed or plaintext depending on users.nix implementation)
admin-password: "REPLACE_ME"

# WireGuard private key (base64, from: wg genkey)
wg-private-key: "REPLACE_ME"

# initrd SSH host key (for LUKS remote unlock via SSH at boot)
# Generate: ssh-keygen -t ed25519 -N "" -f /tmp/initrd_host_key
# Value: contents of /tmp/initrd_host_key (private key)
initrd-host-key: "REPLACE_ME"
